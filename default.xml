<?xml version="1.0" encoding="UTF-8"?>
<manifest>

  <!-- 远程仓库 -->
  <remote name="origin" fetch="ssh://git@github.com/active-ailab/" />

  <!-- 默认配置 -->
  <default remote="origin"
           revision="main"
           sync-j="4"
           clone-depth="1" />

  <!-- manifest 仓库 -->
  <project name="skills-manifest"
           path="manifest" />

  <!-- skills 仓库 -->
  <project name="active-coding-rules"
           path="active-coding-rules" />

  <project name="active-knowledge-suite"
           path="active-knowledge-suite" />

  <project name="active-jira-workflow"
           path="active-jira-workflow" />

  <project name="commit-message-standards"
           path="commit-message-standards" />

  <project name="ui-screen-generator-skill"
           path="ui-screen-generator-skill" />

  <project name="lark_mcp_auth_skills"
           path="lark_mcp_auth_skills" />

  <project name="active-build-script"
           path="active-build-script" />

  <project name="code-review"
           path="code-review" />
		   
  <project name="active_skills_install"
           path="active_skills_install" />

  <project name="active-project-pl-skills"
           path="active-project-pl-skills" />

  <project name="active-gerrit-workflow"
           path="active-gerrit-workflow" />

  <project name="Trace32_CLI"
           path="Trace32_CLI" />

  <project name="wsl-serial-monitor"
           path="wsl-serial-monitor"
           revision="master" />


</manifest>
